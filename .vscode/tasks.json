{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OnlineGame",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}/src/demo.c",
                "${workspaceFolder}/src/game_logic.c",
                "${workspaceFolder}/src/game_ui.c",
                "${workspaceFolder}/src/net_client.c",
                "-o",
                "${workspaceFolder}/Debug/demo.exe",
                "-g",
                "-Wall",
                "-std=c11",
                "-I",
                "${workspaceFolder}/include",
                "-lws2_32",
                "-lgdi32",
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Server",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}/src/net_server.c",
                "-o",
                "${workspaceFolder}/Debug/net_server.exe",
                "-g",
                "-Wall",
                "-std=c11",
                "-I",
                "${workspaceFolder}/include",
                "-lws2_32",
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
        
    ]
}